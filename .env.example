# Copy this file to .env.local and paste your real values.
# These are read ONLY on the server (in app/api/generate/route.ts) and are
# never exposed to the client.

# Your OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# The model to use (any OpenRouter model id).
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Optional: used for OpenRouter request attribution headers.
OPENROUTER_SITE_URL=http://localhost:3000
